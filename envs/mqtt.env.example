# =============================================================================
# MQTT Ingestion Service Configuration
# =============================================================================
# Copy this file to mqtt.env and customize for your environment

# ---- MQTT Broker Configuration ------------------------------------------
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_TOPIC=telemetry/#
MQTT_QOS=1
MQTT_CONNECT_TIMEOUT=10
MQTT_RECONNECT_MIN_DELAY=1
MQTT_RECONNECT_MAX_DELAY=60

# ---- Kafka Configuration ------------------------------------------------
KAFKA_BROKERS=kafka:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TELEMETRY_RAW=telemetry.raw

# ---- HTTP Server Configuration ------------------------------------------
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# ---- Metrics Configuration ----------------------------------------------
METRICS_PORT=9103

# ---- Logging Configuration ----------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---- Application Configuration ------------------------------------------
SERVICE_NAME=mqtt-ingest
ENVIRONMENT=development

# =============================================================================
# Mosquitto Configuration (see devops/mosquitto/mosquitto.conf)
# =============================================================================
# Mosquitto configuration is managed via docker/mosquitto/mosquitto.conf
# Key settings:
#  - listener 1883 (MQTT port)
#  - allow_anonymous true (development only)
#  - persistence true
#  - log_dest stdout (logs to container output)
#
# For production, update mosquitto.conf with:
#  - allow_anonymous false
#  - password_file /mosquitto/config/passwd
#  - acl_file /mosquitto/config/acl
