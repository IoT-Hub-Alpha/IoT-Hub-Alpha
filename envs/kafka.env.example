# Kafka app settings
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=iot-hub-backend
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

KAFKA_TOPIC_TELEMETRY_RAW=telemetry.raw
KAFKA_TOPIC_TELEMETRY_CLEAN=telemetry.clean
KAFKA_TOPIC_TELEMETRY_DLQ=telemetry.dlq
KAFKA_TOPIC_EVENT=event.topic

KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_LINGER_MS=20
KAFKA_PRODUCER_BATCH_SIZE=65536
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_PRODUCER_COMPRESSION_TYPE=none
KAFKA_PUBLISH_MAX_RETRIES=3
KAFKA_RETRY_BACKOFF_BASE_MS=100
KAFKA_RETRY_BACKOFF_MAX_MS=2000
KAFKA_RETRY_BACKOFF_JITTER=0.2

# Kafka infra bootstrap topics (used by docker-compose kafka-init service)
KAFKA_TOPICS=telemetry.raw,telemetry.clean,telemetry.dlq,event.topic